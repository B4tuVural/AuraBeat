# =============================================================
# AuraBeat — Ortam Değişkenleri
# ---------------------------------------------------------
# Bu dosyayı `.env` olarak kopyala ve değerleri doldur:
#   cp .env.example .env   (Linux/macOS)
#   copy .env.example .env (Windows CMD)
# =============================================================

# ----- Django -----
DJANGO_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# ----- PostgreSQL 17 (Docker Compose) -----
# Bu değerler docker-compose.yml ile birebir eşleşir.
# Docker dışında kurulum yapıyorsan burayı kendi sunucuna göre düzenle.
DB_NAME=aurabeat
DB_USER=aurabeat
DB_PASSWORD=aurabeat
DB_HOST=localhost
DB_PORT=5432

# ----- Gemini AI (ZORUNLU) -----
# API anahtarını https://aistudio.google.com/app/apikey adresinden al.
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL_NAME=gemini-2.5-flash

# ----- Spotify (OPSİYONEL) -----
# Albüm kapağı zenginleştirme için. Boş bırakırsan NullMusicService devreye girer.
# https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ----- CORS -----
FRONTEND_ORIGIN=http://localhost:8080
